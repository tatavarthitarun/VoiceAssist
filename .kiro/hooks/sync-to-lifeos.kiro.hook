{
  "name": "Sync Status to LifeOS",
  "version": "1.0.0",
  "when": {
    "type": "agentStop"
  },
  "then": {
    "type": "askAgent",
    "prompt": "Summarize what was accomplished in this session in 2-3 lines. Update .lifeos/project_status.md — add a new session entry at the top with today's date, what was done, and next steps. Update current_state status and latest_update. Also check off any completed Next_actions in .lifeos/README.md and add new ones if needed. Keep it concise."
  }
}
